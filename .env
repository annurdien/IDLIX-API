# Application
PORT=3000

# Target base URL — no trailing slash
IDLIX_BASE_URL=https://z2.idlixku.com

# Puppeteer — set to 'false' to show browser window for debugging
PUPPETEER_HEADLESS=true

# Cache TTL in hours (one per category)
CACHE_TTL_PAGE=1
CACHE_TTL_FEATURED=1
CACHE_TTL_CINEMAXXI=1
CACHE_TTL_TRENDING=1
CACHE_TTL_SERIES=1
CACHE_TTL_MCU=1
CACHE_TTL_HOME=1
CACHE_TTL_DETAIL=2
CACHE_TTL_SEARCH=0.5
CACHE_TTL_LEADERBOARD=1
CACHE_TTL_STREAM=0.25
